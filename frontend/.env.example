VITE_BACKEND_URL=http://localhost:5000/api
# OAuth 2.0 Web client ID from Google Cloud Console (same value as the backend's GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id
# App ID from a Meta for Developers app (same value as the backend's FACEBOOK_APP_ID)
VITE_FACEBOOK_APP_ID=your_facebook_app_id
