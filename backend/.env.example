PORT=5000
MONGO_URI=your_mongo_connection_string
JWT_SECRET=your_jwt_secret
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:5000/api
# --- Email (password-reset) ---
# Default: Gmail. Leave SMTP_HOST unset to keep using these two.
EMAIL_USERNAME=your_gmail_address
EMAIL_PASSWORD=your_gmail_app_password
# To switch providers (Resend, Brevo, SendGrid, ...) set SMTP_HOST and these instead - no code change.
# Example for Resend: SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_USER=resend  SMTP_PASS=<api_key>
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# From address shown to recipients (use a verified domain in production, e.g. no-reply@yourdomain.com)
# EMAIL_FROM=
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# --- Google sign-in ---
# OAuth 2.0 Web client ID from Google Cloud Console (must match the frontend's VITE_GOOGLE_CLIENT_ID).
# Verifies the audience of Google tokens. The client SECRET is NOT needed for the token flows used here.
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id
# --- Facebook sign-in ---
# From a Meta for Developers app (App ID must match the frontend's VITE_FACEBOOK_APP_ID). The secret is
# used server-side to validate that the user's access token was issued to this app.
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
